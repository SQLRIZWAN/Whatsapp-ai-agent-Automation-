rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Users collection - own data only
    match /users/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    // Sessions collection - own sessions only
    match /sessions/{uid}/active/{sessionId} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    // Configurations collection - own config only
    match /configurations/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    // Messages collection - own messages only
    match /messages/{uid}/history/{messageId} {
      allow read: if isAuth() && isOwner(uid);
      allow create: if isAuth() && isOwner(uid) && request.resource.data.uid == uid;
      allow update, delete: if isAuth() && isOwner(uid);
    }

    // Calls collection - own call logs only
    match /calls/{uid}/history/{callId} {
      allow read: if isAuth() && isOwner(uid);
      allow create: if isAuth() && isOwner(uid) && request.resource.data.uid == uid;
      allow update, delete: if isAuth() && isOwner(uid);
    }

    // QR Codes collection - own QR codes only
    match /qrCodes/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    // Device tokens collection - own tokens only
    match /deviceTokens/{uid}/{tokenId} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    // Audit logs collection - own logs only
    match /auditLogs/{uid}/{logId} {
      allow read: if isAuth() && isOwner(uid);
      allow create: if isAuth() && isOwner(uid) && request.resource.data.uid == uid;
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
